{
	"name": "linkportal",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"build": "vp build && wrangler types --check",
		"preview": "node node_modules/wrangler/bin/wrangler.js dev .svelte-kit/cloudflare/_worker.js --port 4173 --show-interactive-dev-session false",
		"prepare": "vp config && svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "vp fmt --check . && vp lint .",
		"format": "vp fmt .",
		"test:unit": "vp test",
		"test": "pnpm test:unit -- --run && pnpm test:e2e",
		"test:e2e": "playwright test",
		"gen": "wrangler types",
		"wrangler": "wrangler",
		"d1:create": "wrangler d1 create linkportal-staging",
		"cf:login": "wrangler login",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:seed": "wrangler d1 execute linkportal-staging --local --file=./src/lib/server/db/seed.sql",
		"db:reset": "node -e \"process.env.CI='true'; const { execSync } = require('child_process'); try { require('fs').rmSync('.wrangler/state', { recursive: true, force: true }); } catch(e) {} execSync('wrangler d1 migrations apply linkportal-staging --local', { stdio: 'inherit' }); execSync('wrangler d1 execute linkportal-staging --local --file=./src/lib/server/db/seed.sql', { stdio: 'inherit' });\"",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"deploy": "pnpm run build && wrangler deploy"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260630.1",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24",
		"better-auth": "~1.6.23",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:",
		"wrangler": "^4.97.0",
		"@vitest/browser-playwright": "4.1.9",
		"vitest-browser-svelte": "^2.1.1",
		"playwright": "^1.60.0"
	},
	"packageManager": "pnpm@11.9.0"
}
